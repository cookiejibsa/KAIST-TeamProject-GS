# Gemini AI API 키 (https://aistudio.google.com/app/apikey 에서 무료 발급)
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# JWT 서명 비밀키 (길고 랜덤한 문자열로 바꿔주세요)
JWT_SECRET=replace-this-with-a-random-string-of-at-least-32-characters

# 프론트와 백엔드를 다른 도메인으로 배포할 때만 설정
# 예: CLIENT_ORIGIN=https://your-frontend.up.railway.app
CLIENT_ORIGIN=

# Railway 볼륨을 사용할 때 권장
# 예: DATA_DIR=/data
DATA_DIR=

# 서버 포트 (기본: 3001)
PORT=3001
